DATABASE_URL=postgresql://user:password@localhost:5432/trustcircle
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-me-to-a-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Exotel / Ozonetel IVR
EXOTEL_SID=<your_exotel_sid>
EXOTEL_TOKEN=<your_exotel_token>
EXOTEL_FROM_NUMBER=<your_exotel_virtual_number>

# USSD Gateway (e.g. Africa's Talking or local provider)
USSD_GATEWAY_URL=<your_ussd_gateway_url>
USSD_API_KEY=<your_ussd_api_key>

# OAuth2 partner webhooks
PARTNER_WEBHOOK_SECRET=<random_secret_for_hmac>

# Fairness audit threshold (fraction, 0.15 = 15%)
FAIRNESS_DISPARITY_THRESHOLD=0.15

# Reinsurance buffer rate
REINSURANCE_RATE=0.005
