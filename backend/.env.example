# =====================================================================
# TrustCircle — Environment Configuration
# =====================================================================

# --- Database (Required) ---
DATABASE_URL=sqlite:///./trustcircle.db

# --- Auth / JWT (Required) ---
SECRET_KEY=change-me-to-a-random-secret-key-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Application ---
ENV=development
DEBUG=true

# --- CORS ---
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Redis / Celery (Person 3) ---
REDIS_URL=redis://localhost:6379/0

# --- Exotel / IVR (Person 3) ---
EXOTEL_SID=<your_exotel_sid>
EXOTEL_TOKEN=<your_exotel_token>
EXOTEL_FROM_NUMBER=<your_exotel_virtual_number>

# --- USSD Gateway (Person 3) ---
USSD_GATEWAY_URL=<your_ussd_gateway_url>
USSD_API_KEY=<your_ussd_api_key>

# --- Partner Webhooks (Person 2/3) ---
PARTNER_WEBHOOK_SECRET=<random_secret_for_hmac>

# --- ML / Fairness (Person 2) ---
FAIRNESS_DISPARITY_THRESHOLD=0.15
REINSURANCE_RATE=0.005
